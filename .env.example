PORT=3001
HF_TOKEN=your_huggingface_token_here
HF_MODEL=Sao10K/L3-8B-Stheno-v3.2
HF_TIMEOUT_MS=120000
DB_PATH=./data/chat.db
MEMORY_MAX_MESSAGES=8
MEMORY_SUMMARY_ENABLED=true
MEMORY_SUMMARY_TRIGGER=30
MEMORY_SUMMARY_EVERY=10
MEMORY_SUMMARY_MAX_CHARS=1200
MEMORY_SUMMARY_MAX_TOKENS=200
OUTFIT_ENABLED=true
OUTFIT_MAX_CHARS=600
OUTFIT_MAX_TOKENS=120
OUTFIT_CONTEXT_MESSAGES=12
CHARACTER_MAX_CHARS=2000
IMAGE_TIMEOUT_MS=120000

# Pollinations API key for zimage image generation
POLLINATIONS_API_KEY=your_pollinations_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-flex
OPENROUTER_IMAGE_ASPECT_RATIO=1:1
OPENROUTER_IMAGE_SIZE=1K
OPENROUTER_IMAGE_MODALITIES=image
OPENROUTER_REFERER=https://your-site.example
OPENROUTER_APP_TITLE=your-app-name
IMAGES_DIR=./images
